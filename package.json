{
  "name": "ink-web-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "bun run --cwd packages/ink-web build",
    "dev": "bun run --cwd packages/ink-web dev",
    "test": "bun run --cwd packages/ink-web test",
    "docs": "bun run --cwd docs dev",
    "docs:build": "bun run build && bun run --cwd docs build"
  }
}
